    "args": { "sources": "code,issues" },
    "expect": [{ "source": "issue", "refPattern": "issue#\\d+", "topN": 6 }]
  },
  {
    "id": "matomo-tracker-code",
    "repo": "https://github.com/matomo-org/matomo",
